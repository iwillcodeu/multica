# Database
# Docker Postgres: make setup && make start
# Local Postgres (Homebrew, etc.): make setup-local && make start-local
POSTGRES_DB=multica
POSTGRES_USER=multica
POSTGRES_PASSWORD=multica
POSTGRES_PORT=5432
DATABASE_URL=postgres://multica:multica@localhost:5432/multica?sslmode=disable

# Server
PORT=8080
JWT_SECRET=change-me-in-production
MULTICA_SERVER_URL=ws://localhost:8080/ws
MULTICA_APP_URL=http://localhost:3000
MULTICA_DAEMON_CONFIG=
MULTICA_WORKSPACE_ID=
MULTICA_DAEMON_ID=
MULTICA_DAEMON_DEVICE_NAME=
MULTICA_DAEMON_POLL_INTERVAL=3s
MULTICA_DAEMON_HEARTBEAT_INTERVAL=15s
MULTICA_CODEX_PATH=codex
MULTICA_CODEX_MODEL=
MULTICA_CODEX_WORKDIR=
MULTICA_CODEX_TIMEOUT=20m

# Email (Resend). Leave RESEND_API_KEY empty for local dev: the server prints the code to its
# stdout as "[DEV] Verification code for ...". With APP_ENV unset or not "production", you can
# also sign in using the fixed code 888888 (see server/internal/handler/auth.go).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@multica.ai

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# S3-compatible object storage (required for issue/comment image uploads). If S3_BUCKET is empty, uploads return 503.
# AWS S3: set S3_BUCKET, S3_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY.
# Aliyun OSS: set S3_ENDPOINT to the API endpoint (VPC internal e.g. https://oss-cn-shanghai-internal.aliyuncs.com or public https://oss-cn-shanghai.aliyuncs.com),
#   S3_REGION=oss-cn-shanghai (match region), CLOUDFRONT_DOMAIN=your public read domain (host only, e.g. cdn.example.com) for URLs returned to the browser.
# MinIO: set S3_ENDPOINT to your MinIO API URL and S3_USE_PATH_STYLE=1.
# Optional: MULTICA_CREDENTIALS_INI=/opt/multica/config.ini — INI with [credentials] and alibaba_cloud_access_key_id / alibaba_cloud_access_key_secret (omit AWS_* from .env).
S3_BUCKET=
S3_REGION=us-west-2
S3_ENDPOINT=
S3_USE_PATH_STYLE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MULTICA_CREDENTIALS_INI=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=multica/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=

# Frontend
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
# Backend origin only — do not add /api (auth is /auth/*, REST is /api/* on same host)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Remote API (optional) — set to proxy local frontend to a remote backend
# Leave empty to use local backend (localhost:8080)
# REMOTE_API_URL=https://multica-api.copilothub.ai

# DingTalk "小安" robot (POST /xiaoanmsg). Run migration 034_dingtalk_xiaoan and insert dingtalk_xiaoan_chat_mapping rows.
# DINGTALK_XIAOAN_SKIP_VERIFY=1 for local testing only (disables callback signature verification).
DINGTALK_XIAOAN_APP_KEY=
DINGTALK_XIAOAN_APP_SECRET=
DINGTALK_XIAOAN_SKIP_VERIFY=
# Comma-separated DingTalk user ids that represent the bot (must be @'d to trigger; used to filter assignee @ list).
DINGTALK_XIAOAN_BOT_USER_IDS=
# Robot code from the DingTalk developer console (for group message replies).
DINGTALK_XIAOAN_ROBOT_CODE=
# Optional emergency fallback if DingTalk directory has no email (id=email, comma-separated).
# Prefer storing bindings in DB: successful lookups and "@小安 补充 发送者邮箱=...; 责任人邮箱=..." are persisted
# to dingtalk_xiaoan_user_email_override (user_id -> email) and used on subsequent requests.
DINGTALK_XIAOAN_USER_EMAIL_MAP=

# Internal API (POST /api/internal/issues/as-user). Shared secret header: X-Internal-Secret
INTERNAL_API_SECRET=
