# Copy to .env.chandao.deploy in repo root (gitignored) for: scripts/deploy/deploy-remote-frontend.sh
#
# DNS: A record pmo.atuofuture.com → 47.103.102.65
# TLS: after nginx serves this host on 80/443, run e.g.
#   apt install certbot python3-certbot-nginx
#   certbot --nginx -d pmo.atuofuture.com
# Before TLS exists, temporarily use HTTP in both this file and server APP_PUBLIC_BASE:
#   NEXT_PUBLIC_WS_URL=ws://pmo.atuofuture.com/ws
# (If Multica nginx listens on 9080, use ws://pmo.atuofuture.com:9080/ws until 80 is free.)

NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=wss://pmo.atuofuture.com/ws
REMOTE_API_URL=http://127.0.0.1:8080
